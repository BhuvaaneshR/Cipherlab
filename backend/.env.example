DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cipherlab
FLASK_APP=app.py
FLASK_ENV=development
OTP_EXPIRY_MINUTES=10
OTP_DELIVERY_MODE=smtp
OTP_SECRET=change-this-secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SENDER=CipherLab <your-email@gmail.com>
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15
